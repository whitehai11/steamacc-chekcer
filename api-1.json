      "post": {
        "operationId": "PlayersController_refreshPlayer",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Player refresh succesfully requested"
          }
        },
        "tags": [
          "Players"
        ]
      }
    }
