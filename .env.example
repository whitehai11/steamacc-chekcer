# Master Steam Bot Dashboard Environment Configuration
# Copy this file to '.env' and edit the values. Do NOT commit the '.env' file.

# ArchiSteamFarm IPC Password (must match the password in asf/config/ASF.json)
ASF_PASSWORD=mein_sicheres_ipc_passwort

# IMAP Password for the Steam Mail Bot
STEAM_MAIL_PASSWORD=dein_tatsächliches_imap_passwort

# CSRep.gg API Credentials (from developer portal)
CSREP_API_KEY=dein_tatsächlicher_csrep_api_key
CSREP_KEY_ID=dein_tatsächlicher_csrep_key_id
